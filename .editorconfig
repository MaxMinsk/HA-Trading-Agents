root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.{cs,csx}]
indent_size = 4

[*.{csproj,props,targets,json,yml,yaml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.cs]
# Namespaces & usings
csharp_style_namespace_declarations = file_scoped:warning
dotnet_sort_system_directives_first = true
csharp_using_directive_placement = outside_namespace:warning

# Prefer modern C#
csharp_style_var_for_built_in_types = true:silent
csharp_style_var_when_type_is_apparent = true:silent
csharp_style_var_elsewhere = true:silent
csharp_prefer_braces = true:warning
csharp_style_prefer_pattern_matching = true:suggestion
csharp_style_expression_bodied_methods = when_on_single_line:suggestion

# Nullable / quality
dotnet_style_qualification_for_field = false:warning
dotnet_style_require_accessibility_modifiers = for_non_interface_members:warning

# Naming: interfaces start with I, types are PascalCase (defaults are fine; left explicit-light)

# --- Muted analyzer rules (rationale required) ---
# CA1032: custom exceptions here are domain-specific and never (de)serialized across boundaries,
#         so the full standard-constructor set adds noise without value.
dotnet_diagnostic.CA1032.severity = none
# MA0048 is satisfied (one type per file); keep Meziantou at its defaults otherwise.

# Test projects: xunit Method_Scenario_Expectation naming needs underscores (CA1707).
[tests/**/*.cs]
dotnet_diagnostic.CA1707.severity = none

# Console hosts: output is human-facing, not localized, and the app has no sync context.
[src/Trading.Cli/**.cs]
dotnet_diagnostic.CA1303.severity = none
dotnet_diagnostic.CA1305.severity = none
dotnet_diagnostic.MA0011.severity = none
dotnet_diagnostic.MA0004.severity = none

[src/Trading.Agent/**.cs]
dotnet_diagnostic.CA1303.severity = none
dotnet_diagnostic.CA1305.severity = none
dotnet_diagnostic.MA0011.severity = none
dotnet_diagnostic.MA0004.severity = none

# MCP server host: low-frequency ingestion/lifecycle logging — LoggerMessage source-gen is overkill here.
[src/Trading.Mcp/**.cs]
dotnet_diagnostic.CA1848.severity = none
