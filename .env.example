# Copy to .env for local runs (scripts/run-local.sh). NEVER commit real keys (.env is gitignored).

# Shared bearer for the MCP endpoint (the data MCP requires it; the agent sends it).
TRADING_BEARER_TOKEN=devtoken

# Crew model: the agent runs locally where the model API is reachable.
TRADING_LLM_PROVIDER=anthropic
TRADING_LLM_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Execution: paper by default (no keys). For the Binance testnet set TRADING_EXEC_MODE=binance and the keys.
TRADING_EXEC_ENABLED=true
TRADING_EXEC_MODE=paper
# TRADING_BINANCE_API_KEY=
# TRADING_BINANCE_API_SECRET=
